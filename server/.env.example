PORT=
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
JWT_SECRET=
JWT_EXPIRES_IN=7d
CLIENT_URL=
PUPPETEER_CACHE_DIR=/opt/render/.cache/puppeteer
PUPPETEER_EXECUTABLE_PATH=
DB_SYNC_ENABLED=false
NODE_ENV=production

# Push notifications (Web Push / VAPID)
# Générer avec : node server/scripts/generate-vapid.js
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@zamor.app

